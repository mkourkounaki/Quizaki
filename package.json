{
  "name": "quizaki",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "concurrently -k -n expo,bsync -c blue,magenta \"npm run dev:expo\" \"npm run dev:bsync\"",
    "dev": "concurrently -k -n expo,bsync -c blue,magenta \"npm run dev:expo\" \"npm run dev:bsync\"",
    "dev:web": "concurrently -k -n expo,bsync -c blue,magenta \"npm run dev:expo\" \"npm run dev:bsync\"",
    "dev:expo": "cross-env BROWSER=none expo start --web",
    "dev:bsync": "wait-on -t 120000 tcp:127.0.0.1:8081 && browser-sync start --config bs-config.cjs",
    "dev:plain": "expo start --web",
    "dev:mobile": "expo start --lan",
    "dev:tunnel": "expo start --tunnel",
    "dev:localhost": "expo start --localhost",
    "android": "expo start --lan --android",
    "test": "jest",
    "lint": "tsc --noEmit",
    "import:questions": "node scripts/xlsx-to-csvRaw.mjs",
    "export:web": "expo export --platform web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "canvas-confetti": "^1.9.4",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1",
    "xlsx": "^0.18.5",
    "@babel/core": "^7.25.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.3.3"
  },
  "private": true
}
